{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "type": "string"
        },
        "logicAppName": {
            "type": "string"
        },        
        "customConnectorName": {
            "type": "string",
            "metadata": {
                "description": "Name of the custom connector"
            }
        },
        "basePath": {
            "defaultValue":"/13ce322a-6bba-43da-bb6a-4d5a48243770",
            "type": "string",
            "metadata": {
                "description": "Fetch the unique ID from the webhook.site endpoint and enter it in this format: /ID"
            }            
        }
    },
    "resources": [
        {
            "type": "Microsoft.Web/customApis",
            "apiVersion": "2016-06-01",
            "name": "[parameters('customConnectorName')]",
            "location": "[parameters('location')]",
            "properties": {
                "displayName": "[parameters('customConnectorName')]",
                "description": "Webhook.site custom connector",
                "iconUri": "https://defaulticons.powerapps.com/defaulticons/api-dedicated.svg",

                "apiType": "Rest",
                "capabilities": [],

                "backendService": {
                    "serviceUrl": "https://webhook.site"
                    },
                "connectionParameters": {},
                "supportedConnectionKinds": "V1,V2",
                "swagger": {
                    "swagger": "2.0",
                    "info": {
                        "title": "Default title",
                        "description": "",
                        "version": "1.0"
                    },
                    "host": "webhook.site",
                    "schemes": ["https"],
                    "consumes": [],
                    "produces": [],
                    "paths": {
                        "[parameters('basePath')]": {
                            "get": {
                                "responses": {
                                    "default": {
                                        "description": "default",
                                        "schema": {

                                        }
                                    }
                                },
                                "summary": "Get Invoke API",
                                "operationId": "GetInvokeAPI",
                                "parameters": []
                            },
                            "post": {
                                "responses": {
                                "default": {
                                    "description": "default",
                                    "schema": {

                                    }
                                }
                                },
                                "parameters": [
                                {
                                    "name": "body",
                                    "in": "body",
                                    "required": false,
                                    "schema": {
                                    "type": "object",
                                    "properties": {
                                        "string": {
                                        "type": "string",
                                        "description": "enter any string"
                                        }
                                    }
                                    }
                                }
                                ],
                                "summary": "Post Invoke API",
                                "operationId": "PostInvokeAPI"
                            }
                        }
                    },
                    "definitions": {},
                    "parameters": {},
                    "responses": {},
                    "security": [],
                    "tags": [],
                    "securityDefinitions": {}
                }
            }
        },
        {
            "type": "Microsoft.web/connections",            
            "dependsOn": [
                "[resourceId('Microsoft.Web/customApis', parameters('customConnectorName'))]"
            ],
            "apiVersion": "2018-07-01-preview",
            "id": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.Web/connections/', parameters('customConnectorName'))]",
            "name": "[parameters('customConnectorName')]",
            "kind": "V1",
            "location": "[parameters('location')]",
            "properties": {
                "displayName": "[parameters('customConnectorName')]",
                "authenticatedUser": {},
                "overallStatus": "Connected",
                "statuses": [
                    {
                        "status": "Connected"
                    }
                ],
                "connectionState": "Enabled",
                "parameterValues": {},
                "customParameterValues": {},
                "api": {
                    "name": "[parameters('customConnectorName')]",
                    "displayName": "[parameters('customConnectorName')]",
                    "description": "",
                    "id": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.Web/customApis/', parameters('customConnectorName'))]",
                    "type": "Microsoft.Web/customApis"
                },
                "testLinks": [],
                "testRequests": []
            }
        },
                {
            "apiVersion": "2016-10-01",
            "name": "[parameters('logicAppName')]",            
            "dependsOn": [
                "[resourceId('Microsoft.Web/connections', parameters('customConnectorName'))]"
            ],
            "type": "Microsoft.Logic/workflows",
            "location": "[parameters('location')]",
            "tags": {},
            "properties": {
                "definition": {
                    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                        "$connections": {
                            "defaultValue": {},
                            "type": "Object"
                        }
                    },
                    "triggers": {
                        "When_an_HTTP_request_is_received": {
                            "type": "Request",
                            "kind": "Http"
                        }
                    },
                    "actions": {
                        "Get_Invoke_API": {
                            "type": "ApiConnection",
                            "inputs": {
                                "host": {
                                    "connection": {
                                        "name": "@parameters('$connections')['custom-connector']['connectionId']"
                                    }
                                },
                                "method": "get",
                                "path": "[parameters('basePath')]"
                            },
                            "runAfter": {}
                        },
                            "Post_Invoke_API": {
                            "type": "ApiConnection",
                            "inputs": {
                                "host": {
                                    "connection": {
                                        "name": "@parameters('$connections')['custom-connector']['connectionId']"
                                    }
                                },
                                "method": "post",
                                "body": {
                                    "string": "hello world"
                                },
                                "path": "[parameters('basePath')]"
                            },
                            "runAfter": {
                                "Get_Invoke_API": [
                                    "SUCCEEDED"
                                ]
                            }
                        }
                    },
                    "outputs": {}
                },
                "parameters": {
                    "$connections": {
                        "value": {
                            "custom-connector": {
                                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.Web/customApis/', parameters('customConnectorName'))]",
                                "connectionId": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', resourceGroup().name, '/providers/Microsoft.Web/connections/', parameters('customConnectorName'))]",
                                "connectionName": "[parameters('customConnectorName')]",
                                "connectionProperties": {}
                            }
                        }
                    }
                },
                "state": "Enabled"
            }
        }
    ]
}
