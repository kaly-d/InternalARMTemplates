{
    "$schema": "https://schema.management.azure.com/schemas/2014-04-01-preview/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "natGatewayName": {
            "type": "String"
        },
        "publicIpAddressesIPv6": {
            "defaultValue": [],
            "type": "Array",
            "metadata": {
                "description": "List of new and existing IPv6 public IP addresses to associate with the NAT Gateway. This array should contain objects in the form { id: <resourceId> }."
            }
        },

        "tags": {
            "defaultValue": {},
            "type": "Object"
        },
        "deployNewPublicIp": {
            "defaultValue": false,
            "type": "Bool"
        },
        "publicIpName": {
            "defaultValue": "nat-pip",
            "type": "String"
        },
        "publicIpVersion": {
            "defaultValue": "IPv4",
            "allowedValues": [
                "IPv4",
                "IPv6"
            ],
            "type": "String"
        },
        "deployNewPublicIpPrefix": {
            "defaultValue": false,
            "type": "Bool"
        },
        "publicIpPrefixName": {
            "defaultValue": "nat-prefix",
            "type": "String"
        },
        "publicIpPrefixLength": {
            "defaultValue": 28,
            "type": "Int",
            "metadata": {
                "description": "The prefix length for the new public IP prefix (e.g., 28 for /28)"
            }
        },
        "publicIpPrefixVersion": {
            "defaultValue": "IPv4",
            "allowedValues": [
                "IPv4",
                "IPv6"
            ],
            "type": "String"
        },
        "sourceVirtualNetwork": {
            "defaultValue": "",
            "type": "String"
        },
        "virtualNetwork": {
            "defaultValue": {"name":"vnet","id":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Network/virtualNetworks/vnet","type":"Microsoft.Network/virtualNetworks","location":"canadacentral","properties":{"provisioningState":"Succeeded","resourceGuid":"6edcd27a-7459-455f-948b-b80993dcb19a","addressSpace":{"addressPrefixes":["10.0.0.0/16"]},"privateEndpointVNetPolicies":"Disabled","subnets":[{"name":"subnet","id":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Network/virtualNetworks/vnet/subnets/subnet","etag":"W/\"3fd59064-39dd-4f7a-81f6-f3cfb4364c14\"","properties":{"provisioningState":"Succeeded","addressPrefix":"10.0.0.0/24","serviceAssociationLinks":[{"name":"AppServiceLink","id":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Network/virtualNetworks/vnet/subnets/subnet/serviceAssociationLinks/AppServiceLink","etag":"W/\"3fd59064-39dd-4f7a-81f6-f3cfb4364c14\"","type":"Microsoft.Network/virtualNetworks/subnets/serviceAssociationLinks","properties":{"provisioningState":"Succeeded","linkedResourceType":"Microsoft.Web/serverfarms","link":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Web/serverfarms/testkalyasp","enabledForArmDeployments":false,"allowDelete":false,"subnetId":"00000000-0000-0000-0000-000000000000","locations":[]}}],"serviceEndpoints":[{"provisioningState":"Succeeded","service":"Microsoft.Storage","locations":["canadacentral","canadaeast"]}],"delegations":[{"name":"delegation","id":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Network/virtualNetworks/vnet/subnets/subnet/delegations/delegation","etag":"W/\"3fd59064-39dd-4f7a-81f6-f3cfb4364c14\"","properties":{"provisioningState":"Succeeded","serviceName":"Microsoft.Web/serverfarms","actions":["Microsoft.Network/virtualNetworks/subnets/action"]},"type":"Microsoft.Network/virtualNetworks/subnets/delegations"}],"privateEndpointNetworkPolicies":"Disabled","privateLinkServiceNetworkPolicies":"Enabled","natGateway":{"id":"/subscriptions/e60a2559-68d5-4df1-ba9f-6ea5e17e0cfb/resourceGroups/KalyaniRG/providers/Microsoft.Network/natGateways/natgw"}},"type":"Microsoft.Network/virtualNetworks/subnets"}],"virtualNetworkPeerings":[],"enableDdosProtection":false},"apiVersion":"2024-10-01"},
            "type": "Object"
        },
        "virtualNetworkResourceGroup": {
            "defaultValue": "",
            "type": "String"
        },
        "publicIpAddressServiceTag": {
            "defaultValue": [],
            "type": "Array"
        },
        "publicIpPrefixServiceTag": {
            "defaultValue": [],
            "type": "Array"
        }
    },
    "variables": {
        "sourceVirtualNetworkObject": "[if(empty(parameters('sourceVirtualNetwork')), null(), createObject('id', parameters('sourceVirtualNetwork')))]"
    },
    "resources": [
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "[parameters('publicIpAddressApiVersion')]",
            "name": "[parameters('publicIpName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "zones": "[parameters('zones')]",
            "properties": {
                "publicIPAllocationMethod": "Static",
                "publicIpAddressVersion": "[parameters('publicIpVersion')]",
                "ipTags": "[parameters('publicIpAddressServiceTag')]"
            },
            "condition": "[parameters('deployNewPublicIp')]"
        },
        {
            "type": "Microsoft.Network/publicIPPrefixes",
            "apiVersion": "[parameters('publicIpPrefixApiVersion')]",
            "name": "[parameters('publicIpPrefixName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]",
                "tier": "Regional"
            },
            "zones": "[parameters('zones')]",
            "properties": {
                "prefixLength": "[parameters('publicIpPrefixLength')]",
                "publicIpAddressVersion": "[parameters('publicIpPrefixVersion')]",
                "ipTags": "[parameters('publicIpPrefixServiceTag')]"
            },
            "condition": "[parameters('deployNewPublicIpPrefix')]"
        },
        {
            "type": "Microsoft.Network/natGateways",
            "apiVersion": "[parameters('natGatewayApiVersion')]",
            "name": "[parameters('natGatewayName')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIpName'))]",
                "[resourceId('Microsoft.Network/publicIPPrefixes', parameters('publicIpPrefixName'))]"
            ],
            "tags": "[parameters('tags')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "zones": "[parameters('zones')]",
            "properties": {
                "publicIPAddresses": "[parameters('publicIpAddressesIPv4')]",
                "publicIPAddressesV6": "[parameters('publicIpAddressesIPv6')]",
                "publicIPPrefixes": "[parameters('publicIpPrefixesIPv4')]",
                "publicIPPrefixesV6": "[parameters('publicIpPrefixesIPv6')]",
                "idleTimeoutInMinutes": "[parameters('idleTimeout')]",
                "sourceVirtualNetwork": "[variables('sourceVirtualNetworkObject')]"
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2017-05-10",
            "name": "VnetAssociation",
            "dependsOn": [
                "[concat('Microsoft.Network/natGateways/', parameters('natGatewayName'))]"
            ],
            "properties": {
                "mode": "Incremental",
                "template": {
                    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "resources": "[array(parameters('virtualNetwork'))]"
                }
            },
            "resourceGroup": "[parameters('virtualNetworkResourceGroup')]",
            "condition": "[not(empty(parameters('virtualNetwork')))]"
        }
    ]
}
